# ROI (0-based indexing, END is exclusive)
row_start, row_end = 130, 670  # lines
col_start, col_end = 150, 750  # samples


def circular_roi_mask(n_rows, n_cols, row_start, row_end, col_start, col_end):
    center_row = (row_start + row_end) // 2
    center_col = (col_start + col_end) // 2
    radius = min(row_end - row_start, col_end - col_start) // 2

    Y, X = np.ogrid[:n_rows, :n_cols]
    mask = (Y - center_row) ** 2 + (X - center_col) ** 2 <= radius ** 2
    return mask, center_row, center_col, radius


def plot_rgb_with_roi(cube, band_idx, center, radius, title, out_path):
    rgb = np.dstack([
        cube[:, :, band_idx['R']],
        cube[:, :, band_idx['G']],
        cube[:, :, band_idx['B']]
    ]).astype(float)

    rgb -= np.nanmin(rgb)
    rgb /= np.nanmax(rgb)

    plt.figure(figsize=(6, 6))
    plt.imshow(rgb)

    circle = plt.Circle(
        (center[1], center[0]),
        radius,
        color='yellow',
        fill=False,
        linewidth=2
    )
    plt.gca().add_patch(circle)

    plt.title(title)
    plt.axis("off")
    plt.savefig(out_path, dpi=300, bbox_inches="tight")
    plt.close()


rgb_wv = {'R': 670, 'G': 550, 'B': 450}

# Target wavelengths (nm)
target_wv = [
    445, 450, 500, 510, 531, 550, 570,
